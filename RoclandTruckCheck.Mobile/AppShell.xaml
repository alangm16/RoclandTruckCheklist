<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RoclandTruckCheck.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RoclandTruckCheck.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
       BackgroundColor="#FFFFFF"
       TitleColor="#1A1A1A">

    <!-- Login (fuera del main, sin NavBar) -->
    <ShellContent Route="LoginPage"
              ContentTemplate="{DataTemplate views:LoginPage}"
              Shell.NavBarIsVisible="False"/>
    <ShellContent Route="ChecklistPage" ContentTemplate="{DataTemplate views:ChecklistPage}" Shell.NavBarIsVisible="False"/>

    <ShellContent Route="TipoAcceso" ContentTemplate="{DataTemplate views:TipoAcceso}" Shell.NavBarIsVisible="False"/>
</Shell>
